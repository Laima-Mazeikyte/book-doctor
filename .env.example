VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase client-side (for anonymous auth in the browser; PUBLIC_ is used by SvelteKit)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only: service role key for webhook handler (reads user_ratings, writes recommendation_log/items). Required for /webhook/recommend.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: same value as the x-webhook-secret header in Supabase Database Webhook config. If set, webhook requests without this header are rejected.
SUPABASE_WEBHOOK_SECRET=

# Optional: BookDoc recommendation API URL (POST with { user_id, ratings }). If unset, webhook still runs but returns no recommended books.
BOOKDOC_RECOMMEND_URL=

# Bunny.net pull zone base URL for book cover images (e.g. https://your-pullzone.b-cdn.net). Covers are loaded as {base}/{book_id}.avif
PUBLIC_BUNNY_COVERS_BASE=
